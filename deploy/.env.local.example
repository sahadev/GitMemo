# 本地部署私有配置。复制为 deploy/.env.local 后按实际值填写。

# 百度站长平台验证码，可选。
BAIDU_VERIFY_CODE=

# GitMemo 下载 manifest。配置后官网下载区优先使用 OSS；不配置则回退 GitHub Releases。
# 示例：
# VITE_DOWNLOAD_MANIFEST_URL=https://gitmemo-downloads.oss-cn-hangzhou.aliyuncs.com/downloads.json
VITE_DOWNLOAD_MANIFEST_URL=

# 官网图片、视频等大静态资源的公开访问前缀。配置后页面会优先从 OSS/CDN 加载。
# 示例：
# VITE_WEBSITE_ASSET_BASE_URL=https://gitmemo-downloads.oss-cn-hangzhou.aliyuncs.com
VITE_WEBSITE_ASSET_BASE_URL=

{
  "name": "GitMemo",
  "description": "Local-first Git-native personal knowledge capture and reuse system.",
  "version": "v1.0.139",
  "website": "https://gitmemo.kakacut.cn",
  "repository": "https://github.com/sahadev/GitMemo",
  "install": {
    "unsupported": [
      "npm global package install",
      "yarn global package install",
      "pnpm global package install"
    ],
    "cli": "bash <(curl -fsSL https://github.com/sahadev/GitMemo/raw/main/scripts/install.sh)",
    "source": "git clone https://github.com/sahadev/GitMemo.git && cd GitMemo && cargo install --path ."
  },
  "desktop": {
    "platforms": [
      "macOS Apple Silicon",
      "macOS Intel",
      "Windows x64"
    ],
    "windowsInstaller": {
      "filename": "gitmemo-windows-v1.0.139-x64-setup.exe",
      "stableUrl": "https://gitmemo.kakacut.cn/desktop/windows/gitmemo-windows-x64-setup.exe",
      "signed": false,
      "note": "Current Windows installers are unsigned and may show a SmartScreen warning."
    }
  },
  "android": {
    "abi": "arm64-v8a",
    "filename": "gitmemo-android-v1.0.139-arm64-v8a-release.apk",
    "url": "https://gitmemo.kakacut.cn/mobile/gitmemo-android-v1.0.139-arm64-v8a-release.apk",
    "sync": "HTTPS remote URL plus access token"
  },
  "data": {
    "defaultPath": "~/.gitmemo",
    "directories": [
      "conversations",
      "notes/manual",
      "notes/scratch",
      "clips",
      "plans",
      "imports"
    ]
  },
  "mcpTools": [
    "cds_search",
    "cds_recent",
    "cds_read",
    "cds_note",
    "cds_manual",
    "cds_stats",
    "cds_sync"
  ]
}

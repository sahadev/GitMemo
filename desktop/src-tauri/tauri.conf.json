{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitMemo",
  "version": "0.1.0",
  "identifier": "dev.gitmemo.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "GitMemo"
    },
    "windows": [
      {
        "title": "GitMemo",
        "width": 960,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
